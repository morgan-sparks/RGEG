chinook_data <- tibble(
temperature_f = c(48.1, 44.1, 52, 42, 44),
days_to_hatch = c(55, 70, 39, 75, 71),
ecotype = c("spring", "spring", "spring", "summer", "summer")
) |>
mutate(temperature_c = celsius(temperature_f))
View(chinook_data)
chinook_data |>
ggplot(aes(x = temperature_f, y = days_to_hatch, color = ecotype)) +
geom_point() +
theme_classic()
chinook_data |>
ggplot(aes(x = temperature_c, y = days_to_hatch, color = ecotype)) +
geom_point() +
theme_classic()
