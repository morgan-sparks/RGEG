talks |>
filter(Place != "Rocky Mountain Research Station, US Forest Service") |>
mutate(
Time = paste0(Year),
Entry = paste(
"``", Title, "''. ",
Place, ".",
sep = ""
)
) |>
select(Time, Entry) %>%
baretable(
align = "llp{14cm}",
size = "\\fontsize{10}{12}",
add.to.row = list(
pos = as.list(seq(NROW(.))),
command = rep("\\\\[-0.32cm]", NROW(.))
)
)
